<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="BatchPay.Frontend.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:BatchPay.Frontend.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="ShellForegroundColor">White</Color>
            <Color x:Key="ShellTabBarForegroundColor">White</Color>
            <Color x:Key="ShellTabBarUnselectedColor">#7B7B7D</Color>
            <Color x:Key="ShellTabBarBackgroundColor">#0F0F10</Color>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:ReferenceEqualsConverter x:Key="ReferenceEqualsConverter" />
        </ResourceDictionary>
    </Application.Resources>

</Application>

