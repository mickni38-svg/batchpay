<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BatchPay.Frontend.Views.FindPersonsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:BatchPay.Frontend.ViewModels"
    xmlns:models="clr-namespace:BatchPay.Frontend.Models"
    x:DataType="vm:FindPersonsViewModel"
    BackgroundColor="#000000"
    Padding="10,8">

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

        <!-- Search row -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              HorizontalOptions="Fill">

            <Frame
                CornerRadius="14"
                BackgroundColor="#0B0B0D"
                HasShadow="False"
                Padding="12,5"
                BorderColor="#1A1D22"
                HorizontalOptions="Fill">

                <Entry
                    Placeholder="Søg navn eller spisested"
                    PlaceholderColor="#8B8F96"
                    TextColor="#EDEDED"
                    FontSize="13"
                    HeightRequest="38"
                    Text="{Binding SearchText}" />
            </Frame>

            <Button
                Grid.Column="1"
                Text="Find"
                BackgroundColor="#0B0B0D"
                TextColor="#EDEDED"
                BorderColor="#1A1D22"
                CornerRadius="14"
                FontSize="13"
                Padding="14,6"
                HeightRequest="38"
                Command="{Binding OpenFindPersonsCommand}" />
        </Grid>

        <!-- Spacer -->
        <BoxView Grid.Row="1"
                 HeightRequest="12"
                 BackgroundColor="Transparent" />

        <!-- List (Users + Merchants) -->
        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding FilteredEntries}"
            SelectionMode="None"
            BackgroundColor="#000000">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SelectableDirectoryEntry">

                    <Grid
                        Padding="10,6"
                        ColumnDefinitions="36,*,36"
                        RowDefinitions="Auto,Auto,Auto"
                        BackgroundColor="#000000">

                        <!-- Avatar -->
                        <Frame
                            WidthRequest="30"
                            HeightRequest="30"
                            CornerRadius="15"
                            Padding="0"
                            BackgroundColor="{Binding AvatarColor}"
                            HasShadow="False"
                            VerticalOptions="Center"
                            Grid.RowSpan="2">

                            <Label
                                Text="{Binding Initials}"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="11"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill" />
                        </Frame>

                        <!-- Name -->
                        <Label
                            Grid.Column="1"
                            Text="{Binding DisplayName}"
                            TextColor="#EDEDED"
                            FontSize="14"
                            LineBreakMode="TailTruncation"
                            VerticalOptions="End" />

                        <!-- Handle + merchant tag -->
                        <HorizontalStackLayout
                            Grid.Column="1"
                            Grid.Row="1"
                            Spacing="8"
                            VerticalOptions="Start">

                            <Label
                                Text="{Binding Handle, StringFormat='@{0}'}"
                                TextColor="#9AA0A6"
                                FontSize="11"
                                Opacity="0.95" />

                            <Frame
                                Padding="6,2"
                                CornerRadius="10"
                                HasShadow="False"
                                BorderColor="#1A1D22"
                                BackgroundColor="#0B0B0D"
                                IsVisible="{Binding IsMerchant}">
                                <Label
                                    Text="Spisested"
                                    FontSize="10"
                                    TextColor="#2FAE7B"
                                    Margin="0" />
                            </Frame>
                        </HorizontalStackLayout>

                        <!-- Right selection area: only tap the ring -->
                        <Grid
                            Grid.Column="2"
                            Grid.RowSpan="2"
                            WidthRequest="28"
                            HeightRequest="28"
                            VerticalOptions="Center"
                            HorizontalOptions="End">

                            <!-- Unselected ring -->
                            <Frame
                                WidthRequest="22"
                                HeightRequest="22"
                                CornerRadius="11"
                                Padding="0"
                                HasShadow="False"
                                BorderColor="#2A2F36"
                                BackgroundColor="Transparent"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsSelected, Converter={StaticResource InverseBoolConverter}}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleSelectCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                            </Frame>

                            <!-- Selected ring + check -->
                            <Frame
                                WidthRequest="22"
                                HeightRequest="22"
                                CornerRadius="11"
                                Padding="0"
                                HasShadow="False"
                                BorderColor="#2FAE7B"
                                BackgroundColor="#0E1116"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding IsSelected}">
                                <Grid>
                                    <Label
                                        Text="✓"
                                        TextColor="#2FAE7B"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Grid>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleSelectCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                            </Frame>

                        </Grid>

                        <!-- Separator -->
                        <BoxView
                            Grid.Row="2"
                            Grid.ColumnSpan="3"
                            HeightRequest="1"
                            Margin="36,8,0,0"
                            BackgroundColor="#1A1D22" />

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom action -->
        <Button
            Grid.Row="3"
            Text="Tilføj til vennelisten"
            BackgroundColor="#0B0B0D"
            TextColor="#EDEDED"
            BorderColor="#1A1D22"
            CornerRadius="16"
            HeightRequest="42"
            FontSize="13"
            Margin="0,10,0,0"
            IsEnabled="{Binding HasSelection}"
            Command="{Binding AddSelectedCommand}" />

    </Grid>
</ContentPage>
