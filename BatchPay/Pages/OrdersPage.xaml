<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BatchPay.Pages.OrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mine ordrer">

    <Grid Padding="16" RowDefinitions="Auto,*">

        <Label Grid.Row="0"
               Text="Mine gruppebetalinger"
               FontSize="22"
               FontAttributes="Bold" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Orders}">
            <CollectionView.EmptyView>
                <Label Text="Du har ingen gruppebetalinger endnu."
                       Opacity="0.7"
                       Margin="0,20,0,0"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="14"
                           HasShadow="False"
                           BackgroundColor="#2A2F36"
                           BorderColor="#3A4048"
                           Padding="14"
                           Margin="0,10,0,0">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Title}"
                                   TextColor="White"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding MerchantName}"
                                   TextColor="#B0B6BF"
                                   FontSize="13" />

                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding Status}"
                                       TextColor="#2ECC71"
                                       FontSize="12" />

                                <Label Text="{Binding ParticipantsCount, StringFormat='Deltagere: {0}'}"
                                       TextColor="#B0B6BF"
                                       FontSize="12" />

                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd-MM HH:mm}'}"
                                       TextColor="#B0B6BF"
                                       FontSize="12" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding GroupOrderCode, StringFormat='Kode: {0}'}"
                                   TextColor="#B0B6BF"
                                   FontSize="12" />
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
