<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="BatchPay.Pages.GroupPaymentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Gruppebetaling">

    <ContentPage.Content>
        <Grid RowDefinitions="Auto,*,Auto" Padding="16">

            <!-- Overskrift og titel-input -->
            <VerticalStackLayout Grid.Row="0" Spacing="8">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" />
                <Entry
                    Text="{Binding Title}"
                    Placeholder="Fx: 'Pizza fredag aften'" />
            </VerticalStackLayout>

            <!-- Liste med venner -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Friends}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnDefinitions="Auto,*">
                            <CheckBox IsChecked="{Binding IsSelected}" />
                            <Label Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Nederste knapper / status -->
            <VerticalStackLayout Grid.Row="2" Spacing="8">
                <Button
                    Text="Opret gruppebetaling"
                    Command="{Binding CreateGroupOrderCommand}" />

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}" />

                <Label Text="{Binding StatusMessage}"
                       LineBreakMode="WordWrap"
                       TextColor="Purple" />
            </VerticalStackLayout>

        </Grid>
    </ContentPage.Content>
</ContentPage>
